{
  "id": "平凡日子里的挣扎",
  "title": "平凡日子里的挣扎",
  "artist": "",
  "youtubeUrl": "https://www.youtube.com/watch?v=BHssgvVxyws",
  "authors": [
    "phucbm"
  ],
  "lines": [
    {
      "id": "1777620544984-0",
      "chinese": "我看过满脸是灰的人",
      "pinyin": "wǒ kàn guò mǎnliǎn shì huī de rén",
      "translations": [
        {
          "lang": "English",
          "text": "I have seen people with faces full of ash."
        },
        {
          "lang": "Vietnamese",
          "text": "Tôi đã từng nhìn thấy người mặt đầy tro"
        }
      ]
    },
    {
      "id": "1777620544984-1",
      "chinese": "笑着说生活多美",
      "pinyin": "xiàozhe shuō shēnghuó duō měi",
      "translations": [
        {
          "lang": "Vietnamese",
          "text": "Cười nói cuộc sống thật đẹp."
        },
        {
          "lang": "English",
          "text": "Smiling, saying life is beautiful."
        }
      ]
    },
    {
      "id": "7fI6PDlhmnla4WBR9897J",
      "chinese": "也见过功成名就的人",
      "pinyin": "yě jiàn guò gōngchéngmíngjiù de rén",
      "translations": [
        {
          "lang": "English",
          "text": "I have also seen people who have achieved fame and success."
        },
        {
          "lang": "Vietnamese",
          "text": "Cũng đã gặp người thành công danh tiếng."
        }
      ]
    },
    {
      "id": "1777620544984-3",
      "chinese": "总是满身酒味",
      "pinyin": "zǒngshì mǎnshēn jiǔwèi",
      "translations": [
        {
          "lang": "Vietnamese",
          "text": "Luôn có mùi rượu trên người."
        },
        {
          "lang": "English",
          "text": "Always smelling of alcohol."
        }
      ]
    },
    {
      "id": "1777620544984-4",
      "chinese": "我看过夜深都不回家的人",
      "pinyin": "wǒ kànguò yèshēn dōu bù huíjiā de rén",
      "translations": [
        {
          "lang": "Vietnamese",
          "text": "Tôi đã thấy người không về nhà dù đêm khuya."
        },
        {
          "lang": "English",
          "text": "I have seen people who never go home even late at night."
        }
      ]
    },
    {
      "id": "1777620544984-5",
      "chinese": "总期待明天多美",
      "pinyin": "zǒng qī dài míngtiān duō měi",
      "translations": [
        {
          "lang": "Vietnamese",
          "text": "Luôn mong đợi ngày mai sẽ đẹp."
        },
        {
          "lang": "English",
          "text": "Always hoping tomorrow will be beautiful."
        }
      ]
    },
    {
      "id": "1777620544984-6",
      "chinese": "也见过看起来不错的人",
      "pinyin": "yě jiàn guò kànqǐlái búcuò de rén",
      "translations": [
        {
          "lang": "Vietnamese",
          "text": "Cũng đã gặp người trông có vẻ tốt."
        },
        {
          "lang": "English",
          "text": "I have also seen people who seem fine."
        }
      ]
    },
    {
      "id": "1777620544984-7",
      "chinese": "偷偷抹眼泪",
      "pinyin": "tōutōu mǒ yǎnlèi",
      "translations": [
        {
          "lang": "Vietnamese",
          "text": "Lặng lẽ lau nước mắt."
        },
        {
          "lang": "English",
          "text": "Secretly wiping away tears."
        }
      ]
    },
    {
      "id": "1777620544984-28",
      "chinese": "我知道",
      "pinyin": "wǒ zhīdào",
      "translations": [
        {
          "lang": "Vietnamese",
          "text": "Tôi biết."
        },
        {
          "lang": "English",
          "text": "I know."
        }
      ]
    },
    {
      "id": "1777620544984-29",
      "chinese": "认真生活的人",
      "pinyin": "rènzhēn shēnghuó de rén",
      "translations": [
        {
          "lang": "Vietnamese",
          "text": "Người sống nghiêm túc."
        },
        {
          "lang": "English",
          "text": "People who live earnestly."
        }
      ]
    },
    {
      "id": "1777620544984-30",
      "chinese": "总是百般滋味",
      "pinyin": "zǒngshì bǎibān zīwèi",
      "translations": [
        {
          "lang": "Vietnamese",
          "text": "Luôn đầy đủ mọi cảm xúc."
        },
        {
          "lang": "English",
          "text": "Always full of myriad flavors."
        }
      ]
    },
    {
      "id": "1777620544984-31",
      "chinese": "也知道",
      "pinyin": "yě zhīdào",
      "translations": [
        {
          "lang": "Vietnamese",
          "text": "Cũng biết."
        },
        {
          "lang": "English",
          "text": "Also know."
        }
      ]
    },
    {
      "id": "1777620544984-32",
      "chinese": "成年人的世界",
      "pinyin": "chéngniánrén de shìjiè",
      "translations": [
        {
          "lang": "Vietnamese",
          "text": "Thế giới của người lớn."
        },
        {
          "lang": "English",
          "text": "The adult world."
        }
      ]
    },
    {
      "id": "1777620544984-33",
      "chinese": "会在瞬间崩溃",
      "pinyin": "huì zài shùnjiān bēngkuì",
      "translations": [
        {
          "lang": "Vietnamese",
          "text": "Sẽ sụp đổ trong chớp mắt."
        },
        {
          "lang": "English",
          "text": "Can collapse in an instant."
        }
      ]
    },
    {
      "id": "1777620544984-34",
      "chinese": "我们都在平凡日子里拼命挣扎",
      "pinyin": "wǒmen dōu zài píngfán rìzi lǐ pīnmìng zhēngzhá",
      "translations": [
        {
          "lang": "Vietnamese",
          "text": "Chúng ta đều trong những ngày bình thường vật lộn hết sức."
        },
        {
          "lang": "English",
          "text": "We are all struggling desperately in ordinary days."
        }
      ]
    },
    {
      "id": "1777620544984-35",
      "chinese": "拼命想活成别人期待的人呐",
      "pinyin": "pīnmìng xiǎnghuó chéng biérén qīdài de rénnà",
      "translations": [
        {
          "lang": "Vietnamese",
          "text": "Cố gắng sống thành người mà người khác mong đợi."
        },
        {
          "lang": "English",
          "text": "Striving to become the person others expect."
        }
      ]
    },
    {
      "id": "1777620544984-36",
      "chinese": "就算四海为家",
      "pinyin": "jiùsuàn sìhǎiwéijiā",
      "translations": [
        {
          "lang": "Vietnamese",
          "text": "Dù coi bốn biển làm nhà."
        },
        {
          "lang": "English",
          "text": "Even if the four seas become home."
        }
      ]
    },
    {
      "id": "1777620544984-37",
      "chinese": "就算风吹雨打",
      "pinyin": "jiùsuàn fēngchuīyǔdǎ",
      "translations": [
        {
          "lang": "Vietnamese",
          "text": "Dù gió mưa."
        },
        {
          "lang": "English",
          "text": "Even if wind blows and rain hits."
        }
      ]
    },
    {
      "id": "1777620544984-38",
      "chinese": "也要微笑着说我还好",
      "pinyin": "yě yào wēixiào zhe shuō wǒ hái hǎo",
      "translations": [
        {
          "lang": "Vietnamese",
          "text": "Cũng phải mỉm cười nói tôi vẫn ổn."
        },
        {
          "lang": "English",
          "text": "Still smile and say I'm okay."
        }
      ]
    },
    {
      "id": "1777620544984-39",
      "chinese": "我们躲在无人的角落里舔舐伤疤",
      "pinyin": "wǒmen duǒ zài wúrén de jiǎoluò lǐ tiǎnshì shāngbā",
      "translations": [
        {
          "lang": "Vietnamese",
          "text": "Chúng ta trốn trong góc không người, liếm vết thương."
        },
        {
          "lang": "English",
          "text": "We hide in empty corners licking our scars."
        }
      ]
    },
    {
      "id": "1777620544984-40",
      "chinese": "拼命的不想让眼泪流下",
      "pinyin": "pīnmìng de bùxiǎng ràng yǎnlèi liúxià",
      "translations": [
        {
          "lang": "Vietnamese",
          "text": "Cố gắng không muốn nước mắt rơi."
        },
        {
          "lang": "English",
          "text": "Striving not to let tears fall."
        }
      ]
    },
    {
      "id": "1777620544984-21",
      "chinese": "就算满身的疤",
      "pinyin": "jiùsuàn mǎnshēn de bā",
      "translations": [
        {
          "lang": "Vietnamese",
          "text": "Dù cơ thể đầy vết sẹo."
        },
        {
          "lang": "English",
          "text": "Even if covered in scars."
        }
      ]
    },
    {
      "id": "1777620544984-22",
      "chinese": "就算丢盔卸甲",
      "pinyin": "jiùsuàn diūkuīxièjiǎ",
      "translations": [
        {
          "lang": "Vietnamese",
          "text": "Dù bỏ áo giáp."
        },
        {
          "lang": "English",
          "text": "Even if we discard armor."
        }
      ]
    },
    {
      "id": "1777620544984-23",
      "chinese": "也不想让别人看自己的笑话",
      "pinyin": "yě bùxiǎng ràng biérén kàn zìjǐ de xiàohuà",
      "translations": [
        {
          "lang": "Vietnamese",
          "text": "Cũng không muốn người khác thấy mình là trò cười."
        },
        {
          "lang": "English",
          "text": "Also don't want others to see our ridicule."
        }
      ]
    },
    {
      "id": "1777620544984-24",
      "chinese": "我看过为生活穿梭的人",
      "pinyin": "wǒ kànguò wéi shēnghuó chuānsuō de rén",
      "translations": [
        {
          "lang": "Vietnamese",
          "text": "Tôi đã thấy người chạy vòng cho cuộc sống."
        },
        {
          "lang": "English",
          "text": "I have seen people who shuttle through life."
        }
      ]
    },
    {
      "id": "1777620544984-25",
      "chinese": "从未分过黑夜和白昼",
      "pinyin": "cóngwèi fēn guò hēiyè hé báizhòu",
      "translations": [
        {
          "lang": "Vietnamese",
          "text": "Chưa bao giờ phân chia đêm và ngày."
        },
        {
          "lang": "English",
          "text": "Never distinguishing night from day."
        }
      ]
    },
    {
      "id": "1777620544984-26",
      "chinese": "也见过衣食无忧的人",
      "pinyin": "yě jiàn guò yīshí wúyōu de rén",
      "translations": [
        {
          "lang": "Vietnamese",
          "text": "Cũng đã gặp người không lo lắng về ăn mặc."
        },
        {
          "lang": "English",
          "text": "I have also seen people without worries about food and clothing."
        }
      ]
    },
    {
      "id": "1777620544984-27",
      "chinese": "总忧心忡忡的满脸忧愁",
      "pinyin": "zǒng yōuxīn chōngchōng de mǎnliǎn yōuchóu",
      "translations": [
        {
          "lang": "Vietnamese",
          "text": "Luôn lo lắng, khuôn mặt đầy buồn phiền."
        },
        {
          "lang": "English",
          "text": "Always worried, with a face full of sorrow."
        }
      ]
    },
