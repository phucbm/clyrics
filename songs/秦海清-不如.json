        }
      ]
    },
    {
      "id": "1777781861893-31",
      "chinese": "把爱藏在相遇的缝隙",
      "pinyin": "bǎ ài cángzài xiāngyù de fèngxì",
      "translations": [
        {
          "lang": "Vietnamese",
          "text": "Giấu tình yêu trong khe hở của cuộc gặp"
        }
      ]
    },
    {
      "id": "1777781861894-32",
      "chinese": "不如含着眼泪说你好",
      "pinyin": "bùrú hán zhuó yǎnlèi shuō nǐhǎo",
      "translations": [
        {
          "lang": "Vietnamese",
          "text": "Thà ngậm nước mắt nói lời chào"
        }
      ]
    },
    {
      "id": "1777781861894-33",
      "chinese": "你好不好再也不重要",
      "pinyin": "nǐ hǎo buhǎo zàiyě búzhòngyào",
      "translations": [
        {
          "lang": "Vietnamese",
          "text": "Bạn có ổn hay không không còn quan trọng"
        }
      ]
    },
    {
      "id": "1777781861895-34",
      "chinese": "不如将过去统统丢掉",
      "pinyin": "bùrú jiāng guòqù tǒngtǒng diūdiào",
      "translations": [
        {
          "lang": "Vietnamese",
          "text": "Thà bỏ hết quá khứ"
        }
      ]
    },
    {
      "id": "1777781861895-35",
      "chinese": "留在记忆最美的一角",
      "pinyin": "liúzài jìyì zuì měi de yìjiǎo",
      "translations": [
        {
          "lang": "Vietnamese",
          "text": "Giữ lại góc đẹp nhất trong ký ức"
        }
      ]
    },
    {
      "id": "1777781861895-36",
      "chinese": "不如掉进爱情的游戏",
      "pinyin": "bùrú diàojìn àiqíng de yóuxì",
      "translations": [
        {
          "lang": "Vietnamese",
          "text": "Thà rơi vào trò chơi tình yêu"
        }
      ]
    },
    {
      "id": "1777781861896-37",
      "chinese": "反正主角已不再是你",
      "pinyin": "fǎnzhèng zhǔjué yǐ búzài shì nǐ",
      "translations": [
        {
          "lang": "Vietnamese",
          "text": "Dù sao thì nhân vật chính không còn là bạn"
        }
      ]
    },
    {
      "id": "1777781861896-38",
      "chinese": "不如偶尔相遇在梦里",
      "pinyin": "bùrú ǒuěr xiāngyù zài mèng lǐ",
      "translations": [
        {
          "lang": "Vietnamese",
          "text": "Thà thỉnh thoảng gặp nhau trong mơ"
        }
      ]
    },
    {
      "id": "1777781861896-39",
      "chinese": "就算流泪也别把我吵醒",
      "pinyin": "jiùsuàn liúlèi yě bié bǎwǒ chǎoxǐng",
      "translations": [
        {
          "lang": "Vietnamese",
          "text": "Dù có rơi nước mắt cũng đừng đánh thức tôi"
        }
      ]
    }
  ],
