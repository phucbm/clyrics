# Author's Groq API key — set this in Cloudflare Pages environment variables
# Get a free key at https://console.groq.com
# Leave empty: users will be prompted to enter their own key in Settings
VITE_GROQ_API_KEY=

# GitHub PAT for song contributions (fine-grained, contents + pull requests on phucbm/clyrics only)
VITE_GITHUB_TOKEN=
VITE_GITHUB_USERNAME=phucbm
