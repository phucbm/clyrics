# Author's Groq API key — set this in Cloudflare Pages environment variables
# Get a free key at https://console.groq.com
# Leave empty: users will be prompted to enter their own key in Settings
VITE_GROQ_API_KEY=

# GitHub App for song contributions (creates PRs as clyrics-app[bot])
# Create at github.com/settings/apps — needs Contents + Pull requests (read & write)
VITE_GITHUB_APP_ID=
VITE_GITHUB_APP_INSTALLATION_ID=
# Private key: paste PEM content, replace newlines with \n
VITE_GITHUB_APP_PRIVATE_KEY=
